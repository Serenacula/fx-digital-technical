---

---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Image Dominant Colour Finder</title>
        <style is:global>
            :root {
                --colour-title: #f4e3c6;
                --colour-text: #111;
                --colour-subtext-image: #999;
                --colour-subtext-controls: #555;
                --colour-hint: #bbb;
                --colour-bg: #355c7d;
                --colour-panel-bg: #fff;
                --colour-image-area: #fafafa;
                --colour-image-area-hover: #f2f2f2;
                --colour-slider-fill: #c06c84;
                --colour-slider-track: #ddd;
                --colour-slider-handle: #f67280;
                --colour-bar-track: #f0f0f0;
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family:
                    system-ui,
                    -apple-system,
                    sans-serif;
                background: var(--colour-bg);
                color: var(--colour-text);
                min-height: 100vh;
                padding: 2rem;

                @media (max-width: 639px) {
                    padding: 1.25rem;
                }
            }

            .page-header {
                display: flex;
                align-items: baseline;
                justify-content: space-between;
                margin-bottom: 1.5rem;

                h1 {
                    font-size: 2.1rem;
                    font-weight: 600;
                    letter-spacing: -0.02em;
                    color: var(--colour-title);
                }

                .github-link {
                    display: flex;
                    align-items: center;
                    gap: 0.4rem;
                    font-size: 0.85rem;
                    color: var(--colour-slider-handle);
                    text-decoration: none;
                    transition: color 0.15s;

                    &:hover { color: #ffb3be; }
                }
            }

            .layout {
                display: grid;
                grid-template-columns: 340px 1fr;
                gap: 1.5rem;
                height: calc(100vh - 6.5rem);

                @media (max-width: 639px) {
                    grid-template-columns: 1fr;
                    height: auto;
                }
            }

            .left-column {
                display: flex;
                flex-direction: column;
                gap: 1rem;
                min-height: 0;
            }

            .preview-card {
                border: 1px solid #ddd;
                border-radius: 6px;
                overflow: hidden;
                flex-shrink: 0;
                transition: border-color 0.15s;

                &:hover {
                    border-color: #aaa;
                }

                .preview-area {
                    width: 100%;
                    aspect-ratio: 1;
                    padding: 1rem;
                    background: var(--colour-image-area);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    overflow: hidden;
                    cursor: pointer;
                    transition: background 0.15s;

                    &:hover {
                        background: var(--colour-image-area-hover);
                    }

                    .preview-image {
                        display: none;
                        width: 100%;
                        height: 100%;
                        object-fit: contain;

                        &.visible {
                            display: block;
                            & ~ .preview-placeholder {
                                display: none;
                            }
                        }
                    }

                    .preview-placeholder {
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        gap: 0.5rem;
                        color: var(--colour-hint);
                        font-size: 0.8rem;
                        pointer-events: none;
                        user-select: none;

                        .preview-placeholder-formats {
                            font-size: 0.62rem;
                            letter-spacing: 0.02em;
                        }
                    }
                }

                .image-details {
                    padding: 0.5rem 0.75rem;
                    border-top: 1px solid #ddd;
                    background: var(--colour-panel-bg);

                    .detail-name {
                        font-size: 0.85rem;
                        font-weight: 500;
                        color: var(--colour-text);
                        white-space: nowrap;
                        overflow: hidden;
                        text-overflow: ellipsis;
                        min-height: 1.2em;
                    }

                    .detail-meta {
                        font-size: 0.78rem;
                        color: var(--colour-subtext-image);
                        margin-top: 0.2rem;
                        min-height: 1.2em;
                    }
                }
            }

            .controls {
                background: var(--colour-panel-bg);
                border: 1px solid #ddd;
                border-radius: 6px;
                padding: 1rem;
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                flex: 1;
                min-height: 0;

                .slider-group {
                    display: flex;
                    flex-direction: column;
                    gap: 0.4rem;

                    .slider-header {
                        display: flex;
                        justify-content: space-between;
                        align-items: baseline;
                        font-size: 0.85rem;
                        padding-bottom: 6px;
                        color: var(--colour-subtext-controls);

                        strong {
                            color: var(--colour-text);
                            font-weight: 600;
                            font-variant-numeric: tabular-nums;
                        }
                    }

                    .slider {
                        width: 100%;
                        cursor: pointer;
                        -webkit-appearance: none;
                        appearance: none;
                        height: 4px;
                        border-radius: 2px;
                        outline: none;

                        &::-webkit-slider-runnable-track {
                            background: linear-gradient(
                                to right,
                                var(--colour-slider-fill)
                                    var(--fill-pct, 14.29%),
                                var(--colour-slider-track)
                                    var(--fill-pct, 14.29%)
                            );
                            height: 4px;
                            border-radius: 2px;
                        }

                        &::-webkit-slider-thumb {
                            -webkit-appearance: none;
                            appearance: none;
                            width: 16px;
                            height: 16px;
                            border-radius: 50%;
                            background: var(--colour-slider-handle);
                            border: 2px solid #000;
                            cursor: pointer;
                            margin-top: -6px;
                        }

                        &::-moz-range-track {
                            background: var(--colour-slider-track);
                            height: 4px;
                            border-radius: 2px;
                        }

                        &::-moz-range-progress {
                            background: var(--colour-slider-fill);
                            height: 4px;
                            border-radius: 2px;
                        }

                        &::-moz-range-thumb {
                            width: 16px;
                            height: 16px;
                            border-radius: 50%;
                            background: var(--colour-slider-handle);
                            border: 2px solid #000;
                            cursor: pointer;
                            box-sizing: border-box;
                        }

                        &:disabled {
                            opacity: 0.4;
                            cursor: not-allowed;
                        }
                    }

                    .slider-hints {
                        display: flex;
                        justify-content: space-between;
                        font-size: 0.72rem;
                        color: var(--colour-hint);
                    }
                }

            }

            .right-column {
                background: var(--colour-panel-bg);
                border: 1px solid #ddd;
                border-radius: 6px;
                padding: 1.25rem 1.5rem;
                overflow-y: auto;
                min-height: 0;

                @media (max-width: 639px) {
                    overflow-y: visible;
                    min-height: 300px;
                }

                .empty-state,
                .loading-state {
                    height: 100%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 0.95rem;
                    color: var(--colour-subtext-image);

                    @media (max-width: 639px) {
                        height: 200px;
                    }
                }

                .error-state {
                    padding: 1rem 0;
                    font-size: 0.9rem;
                    color: #c00;
                }

                .chart {
                    display: none;
                    flex-direction: column;
                    gap: 0.6rem;

                    &.visible {
                        display: flex;
                    }

                    .chart-row {
                        display: flex;
                        align-items: center;
                        gap: 0.75rem;

                        .colour-label {
                            font-family:
                                ui-monospace, "SF Mono", Menlo, monospace;
                            font-size: 0.8rem;
                            color: var(--colour-text);
                            min-width: 5.5rem;
                            flex-shrink: 0;
                            display: flex;
                            flex-direction: column;

                            .colour-grouping {
                                font-size: 0.68rem;
                                color: #999;
                                margin-top: 0.15rem;
                            }
                        }

                        .bar-track {
                            flex: 1;
                            height: 1.75rem;
                            background: var(--colour-bar-track);
                            border-radius: 3px;
                            overflow: hidden;

                            .bar {
                                height: 100%;
                                border-radius: 3px;
                                min-width: 2px;
                                border: 1px solid #000;
                                transition: width 0.15s ease;
                            }
                        }

                        .percentage-label {
                            font-size: 0.8rem;
                            color: #666;
                            min-width: 3.25rem;
                            flex-shrink: 0;
                            text-align: right;
                            font-variant-numeric: tabular-nums;
                        }

                        .exclude-btn {
                            flex-shrink: 0;
                            width: 22px;
                            height: 22px;
                            padding: 2px;
                            border: none;
                            background: none;
                            cursor: pointer;
                            color: var(--colour-hint);
                            border-radius: 3px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            transition: color 0.1s;

                            &:hover { color: #005792; }
                        }

                        &.excluded {
                            .colour-label,
                            .bar-track,
                            .percentage-label { opacity: 0.45; }

                            .exclude-btn {
                                color: var(--colour-text);
                                opacity: 0.45;
                                &:hover {
                                    color: #b74242;
                                    opacity: 1;
                                }
                            }
                        }
                    }
                }
            }

            .drop-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.35);
                z-index: 100;
                align-items: center;
                justify-content: center;
                pointer-events: none;

                &.visible {
                    display: flex;
                }

                .drop-hint {
                    background: var(--colour-panel-bg);
                    border: 2px dashed #444;
                    border-radius: 8px;
                    padding: 2.5rem 4rem;
                    font-size: 1rem;
                    font-weight: 500;
                    color: #333;
                }
            }
        </style>
    </head>
    <body>
        <div class="page-header">
            <h1>Image Dominant Colour Finder</h1>
            <a
                href="https://github.com/Serenacula/fx-digital-technical"
                class="github-link"
                target="_blank"
                rel="noopener noreferrer"
            >
                View source
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
            </a>
        </div>
        <div class="layout">
            <div class="left-column">
                <div class="preview-card">
                    <div class="preview-area" id="preview-area">
                        <img
                            id="preview-image"
                            class="preview-image"
                            alt="Uploaded image preview"
                        />
                        <div class="preview-placeholder">
                            <svg
                                width="32"
                                height="32"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                            <span>Click or drag an image here</span>
                            <span class="preview-placeholder-formats">JPEG · PNG · WebP · AVIF · BMP</span>
                        </div>
                    </div>
                    <div id="image-details" class="image-details">
                        <div class="detail-name" id="detail-name"></div>
                        <div class="detail-meta" id="detail-meta"></div>
                    </div>
                </div>
                <div class="controls">
                    <div class="slider-group">
                        <div class="slider-header">
                            <label for="quantize-slider">Quantisation</label>
                            <strong id="slider-value">10</strong>
                        </div>
                        <input
                            id="quantize-slider"
                            class="slider"
                            type="range"
                            min="1"
                            max="64"
                            step="1"
                            value="10"
                            disabled
                        />
                        <div class="slider-hints">
                            <span>Exact colours</span>
                            <span>Broadly merged</span>
                        </div>
                    </div>

                </div>
            </div>
            <div class="right-column">
                <div id="empty-state" class="empty-state">
                    Upload an image to see its dominant colours
                </div>
                <div
                    id="loading-state"
                    class="loading-state"
                    style="display: none;"
                >
                    Analysing…
                </div>
                <div
                    id="error-state"
                    class="error-state"
                    style="display: none;"
                >
                </div>
                <div id="chart" class="chart"></div>
            </div>
        </div>

        <input
            id="file-input"
            type="file"
            accept=".jpg,.jpeg,.png,.webp,.avif,.bmp,image/jpeg,image/png,image/webp,image/avif,image/bmp"
            style="display: none;"
        />
        <div id="drop-overlay" class="drop-overlay">
            <div class="drop-hint">Drop image here</div>
        </div>

        <script>
            import { getForm } from "../lib/form.ts"
            import { ImageProcessor, ValidationError, MIME_TYPE_LABELS } from "../lib/image-processor.ts"
            import { AggregationEngine } from "../lib/aggregation-engine.ts"
            import { BarChart, ChartDisplay } from "../lib/bar-chart.ts"
            import { Controls } from "../lib/controls.ts"
            import { DropHandler } from "../lib/drop-handler.ts"

            const form = getForm(document)
            const imageProcessor = new ImageProcessor()
            const engine = new AggregationEngine(imageProcessor)
            const barChart = new BarChart(form.chart, form.emptyPanel, form.loadingPanel, form.errorPanel, engine)
            const controls = new Controls(form.slider, form.sliderValue)
            const dropHandler = new DropHandler(form.dropOverlay, form.dropHint)

            function showLoading(): void {
                dropHandler.busy = true
                controls.disable()
                barChart.showMessage(ChartDisplay.Loading)
                form.fileInput.disabled = true
            }

            function showError(message: string): void {
                dropHandler.busy = false
                controls.disable()
                barChart.showMessage(ChartDisplay.Error, message)
                form.detailName.textContent = ""
                form.detailMeta.textContent = ""
                form.fileInput.disabled = false
                form.previewImage.src = ""
                form.previewImage.classList.remove("visible")
            }

            function runRenderPipeline(): void {
                if (dropHandler.busy) {
                    return
                }
                if (!imageProcessor.rawMap) {
                    return
                }
                const bucketSize = controls.bucketSize
                if (!Number.isFinite(bucketSize) || bucketSize < 1) {
                    return
                }
                const { included, excluded } = engine.aggregateRgb(bucketSize)
                barChart.render(included, excluded, bucketSize)
                dropHandler.busy = false
                controls.enable()
                form.fileInput.disabled = false
            }

            barChart.onToggle = runRenderPipeline
            controls.onBucketSizeChange = runRenderPipeline

            async function onFileSelected(file: File): Promise<void> {
                form.previewImage.onload = null
                try {
                    engine.resetBlacklist()
                    showLoading()
                    await imageProcessor.handleFile(file)
                    form.detailName.textContent = file.name
                    form.previewImage.onload = () => {
                        // naturalWidth/naturalHeight are only available after image decode completes
                        form.detailMeta.textContent = `${MIME_TYPE_LABELS[file.type] ?? file.type} · ${form.previewImage.naturalWidth} × ${form.previewImage.naturalHeight} px`
                    }
                    form.previewImage.src = ""
                    form.previewImage.src = imageProcessor.previewUrl!
                    form.previewImage.classList.add("visible")
                    dropHandler.busy = false
                    runRenderPipeline()
                } catch (error) {
                    showError(error instanceof ValidationError ? error.message : "Could not read image.")
                    form.previewImage.classList.remove("visible")
                    form.previewImage.src = ""
                }
            }

            dropHandler.onFileDrop = (file) => onFileSelected(file).catch(() => {})

            form.previewArea.addEventListener("click", () => form.fileInput.click())

            form.fileInput.addEventListener("change", () => {
                if (dropHandler.busy) {
                    return
                }
                const file = form.fileInput.files?.[0]
                if (file) {
                    onFileSelected(file).catch(() => {})
                    form.fileInput.value = ""
                }
            })
        </script>
    </body>
</html>
