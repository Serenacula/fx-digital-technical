---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Image Dominant Colour Finder</title>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #f5f5f5;
        color: #111;
        min-height: 100vh;
        padding: 2rem;
      }

      h1 {
        font-size: 1.4rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-bottom: 1.5rem;
      }

      .layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 1.5rem;
        height: calc(100vh - 6.5rem);
      }

      /* ── Left column ── */

      .left-column {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-height: 0;
      }

      .preview-area {
        width: 100%;
        height: 220px;
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #fafafa;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
      }

      .preview-area:hover {
        border-color: #aaa;
        background: #f2f2f2;
      }

      .drop-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 100;
        align-items: center;
        justify-content: center;
        pointer-events: none;
      }

      .drop-overlay.visible {
        display: flex;
      }

      .drop-hint {
        background: #fff;
        border: 2px dashed #444;
        border-radius: 8px;
        padding: 2.5rem 4rem;
        font-size: 1rem;
        font-weight: 500;
        color: #333;
      }

      .preview-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: #bbb;
        font-size: 0.8rem;
        pointer-events: none;
        user-select: none;
      }

      .preview-image {
        display: none;
        width: 100%;
        height: 100%;
        object-fit: contain;
        cursor: pointer;
      }

      .preview-image.visible {
        display: block;
      }

      .preview-image.visible ~ .preview-placeholder {
        display: none;
      }

      .controls {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
        min-height: 0;
      }

      /* ── Image details (shown after upload) ── */

      .image-details {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #eee;
      }

      .detail-name {
        font-size: 0.85rem;
        font-weight: 500;
        color: #111;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .detail-meta {
        font-size: 0.78rem;
        color: #999;
        margin-top: 0.2rem;
      }

      /* ── Slider ── */

      .slider-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .slider-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-size: 0.85rem;
        color: #555;
      }

      .slider-header strong {
        color: #111;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }

      .slider {
        width: 100%;
        cursor: pointer;
        accent-color: #111;
      }

      .slider:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }

      .slider-hints {
        display: flex;
        justify-content: space-between;
        font-size: 0.72rem;
        color: #bbb;
      }

      /* ── Right column ── */

      .right-column {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 1.25rem 1.5rem;
        overflow-y: auto;
        min-height: 0;
      }

      .empty-state,
      .loading-state {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        color: #999;
      }

      .error-state {
        padding: 1rem 0;
        font-size: 0.9rem;
        color: #c00;
      }

      /* ── Bar chart ── */

      .chart {
        display: none;
        flex-direction: column;
        gap: 0.6rem;
      }

      .chart.visible {
        display: flex;
      }

      .chart-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .colour-label {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 0.8rem;
        color: #444;
        min-width: 5.5rem;
        flex-shrink: 0;
      }

      .bar-track {
        flex: 1;
        height: 1.75rem;
        background: #f0f0f0;
        border-radius: 3px;
        overflow: hidden;
      }

      .bar {
        height: 100%;
        border-radius: 3px;
        min-width: 2px;
        border: 1px solid #000;
        transition: width 0.15s ease;
      }

      .percentage-label {
        font-size: 0.8rem;
        color: #666;
        min-width: 3.25rem;
        flex-shrink: 0;
        text-align: right;
        font-variant-numeric: tabular-nums;
      }

      /* ── Mobile: stack layout, natural page scroll ── */

      @media (max-width: 639px) {
        body {
          padding: 1.25rem;
        }

        .layout {
          grid-template-columns: 1fr;
          height: auto;
        }

        .right-column {
          overflow-y: visible;
          min-height: 300px;
        }

        .empty-state,
        .loading-state {
          height: 200px;
        }
      }
    </style>
  </head>
  <body>
    <h1>Image Dominant Colour Finder</h1>
    <div class="layout">
      <div class="left-column">
        <div class="preview-area" id="preview-area">
          <img
            id="preview-image"
            class="preview-image"
            alt="Uploaded image preview"
          />
          <div class="preview-placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span>Click or drag an image here</span>
          </div>
        </div>
        <div class="controls">
          <div id="image-details" class="image-details" style="display: none;">
            <div class="detail-name" id="detail-name"></div>
            <div class="detail-meta" id="detail-meta"></div>
          </div>
          <div class="slider-group">
            <div class="slider-header">
              <label for="quantize-slider">Colour grouping</label>
              <strong id="slider-value">10</strong>
            </div>
            <input
              id="quantize-slider"
              class="slider"
              type="range"
              min="1"
              max="64"
              step="1"
              value="10"
              disabled
            />
            <div class="slider-hints">
              <span>Exact colours</span>
              <span>Broadly merged</span>
            </div>
          </div>
        </div>
      </div>
      <div class="right-column">
        <div id="empty-state" class="empty-state">
          Upload an image to see its dominant colours
        </div>
        <div id="loading-state" class="loading-state" style="display: none;">
          Analysing…
        </div>
        <div id="error-state" class="error-state" style="display: none;"></div>
        <div id="chart" class="chart"></div>
      </div>
    </div>

    <input
      id="file-input"
      type="file"
      accept=".jpg,.jpeg,.png,.webp,.avif,.bmp,image/jpeg,image/png,image/webp,image/avif,image/bmp"
      style="display: none;"
    />
    <div id="drop-overlay" class="drop-overlay">
      <div class="drop-hint">Drop image here</div>
    </div>

    <script>
      import { reaggregate, sortedColours } from '../lib/colour-algorithm.ts';
      import { processImage, ValidationError } from '../lib/image-processor.ts';
      import type { RawMap, ColourEntry } from '../lib/colour-algorithm.ts';

      declare global {
        interface Window {
          __lastResult: { map: RawMap; totalPixels: number } | undefined;
          __lastRendered: ColourEntry[] | undefined;
          __recalcCount: number;
          __delayProcessing: number | undefined;
          __createObjectURLCount: number | undefined;
        }
      }

      const fileInput = document.getElementById('file-input') as HTMLInputElement;
      const previewArea = document.getElementById('preview-area') as HTMLDivElement;
      const previewImage = document.getElementById('preview-image') as HTMLImageElement;
      const dropOverlay = document.getElementById('drop-overlay') as HTMLDivElement;
      const imageDetails = document.getElementById('image-details') as HTMLDivElement;
      const detailName = document.getElementById('detail-name') as HTMLDivElement;
      const detailMeta = document.getElementById('detail-meta') as HTMLDivElement;
      const slider = document.getElementById('quantize-slider') as HTMLInputElement;
      const sliderValue = document.getElementById('slider-value') as HTMLSpanElement;
      const emptyState = document.getElementById('empty-state') as HTMLDivElement;
      const loadingState = document.getElementById('loading-state') as HTMLDivElement;
      const errorState = document.getElementById('error-state') as HTMLDivElement;
      const chart = document.getElementById('chart') as HTMLDivElement;

      let rawMap: RawMap | null = null;
      let totalPixels: number = 0;
      let debounceTimer: ReturnType<typeof setTimeout> | undefined;
      let isProcessing: boolean = false;

      window.__recalcCount = 0;
      window.__delayProcessing = undefined;
      window.__lastResult = undefined;
      window.__lastRendered = undefined;

      const mimeTypeLabels: Record<string, string> = {
        'image/jpeg': 'JPEG',
        'image/png': 'PNG',
        'image/webp': 'WebP',
        'image/avif': 'AVIF',
        'image/bmp': 'BMP',
      };

      function showLoading(): void {
        isProcessing = true;
        emptyState.style.display = 'none';
        loadingState.style.display = '';
        errorState.style.display = 'none';
        chart.classList.remove('visible');
        fileInput.disabled = true;
        slider.disabled = true;
      }

      function showError(message: string): void {
        isProcessing = false;
        emptyState.style.display = 'none';
        loadingState.style.display = 'none';
        errorState.style.display = '';
        errorState.textContent = message;
        chart.classList.remove('visible');
        imageDetails.style.display = 'none';
        fileInput.disabled = false;
        slider.disabled = true;
        rawMap = null;
        totalPixels = 0;
      }

      function renderChart(entries: ColourEntry[]): void {
        isProcessing = false;
        chart.innerHTML = '';

        for (const entry of entries) {
          const row = document.createElement('div');
          row.className = 'chart-row';

          const label = document.createElement('span');
          label.className = 'colour-label';
          label.textContent = entry.isTransparent ? 'transparent' : entry.hex;
          row.appendChild(label);

          const barContainer = document.createElement('div');
          barContainer.className = 'bar-track';

          const bar = document.createElement('div');
          bar.className = 'bar';
          bar.style.width = `${entry.percentage}%`;

          if (entry.isTransparent) {
            bar.style.background =
              'repeating-linear-gradient(45deg, #ccc 0px, #ccc 4px, #fff 4px, #fff 8px)';
            bar.style.border = '1px solid black';
          } else {
            bar.style.backgroundColor = entry.hex;
          }

          barContainer.appendChild(bar);
          row.appendChild(barContainer);

          const percentLabel = document.createElement('span');
          percentLabel.className = 'percentage-label';
          percentLabel.textContent = `${entry.percentage.toFixed(1)}%`;
          row.appendChild(percentLabel);

          chart.appendChild(row);
        }

        emptyState.style.display = 'none';
        loadingState.style.display = 'none';
        errorState.style.display = 'none';
        chart.classList.add('visible');
        fileInput.disabled = false;
        slider.disabled = false;

        if (import.meta.env.DEV) {
          window.__lastRendered = entries;
          window.__recalcCount = window.__recalcCount + 1;
        }
      }

      function runRenderPipeline(): void {
        if (rawMap === null) return;
        const bucketSize = parseInt(slider.value, 10);
        if (!Number.isFinite(bucketSize) || bucketSize < 1) return;
        const aggregated = reaggregate(rawMap, bucketSize);
        const entries = sortedColours(aggregated, totalPixels);
        renderChart(entries);
      }

      async function handleFile(file: File): Promise<void> {
        showLoading();

        const fileReaderPromise = new Promise<string>((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(reader.result as string);
          reader.onerror = () => reject(new Error('Could not read image.'));
          reader.onabort = () => reject(new Error('Could not read image.'));
          reader.readAsDataURL(file);
        });

        const processImagePromise = (async () => {
          if (import.meta.env.DEV) {
            const delay = window.__delayProcessing;
            if (delay !== undefined && delay > 0) {
              await new Promise(resolve => setTimeout(resolve, delay));
            }
          }
          return processImage(file);
        })();

        try {
          const [previewUrl, result] = await Promise.all([fileReaderPromise, processImagePromise]);
          rawMap = result.map;
          totalPixels = result.totalPixels;

          if (import.meta.env.DEV) {
            window.__lastResult = { map: rawMap, totalPixels };
          }

          previewImage.onload = () => {
            const typeLabel = mimeTypeLabels[file.type] ?? file.type;
            detailName.textContent = file.name;
            detailMeta.textContent = `${typeLabel} · ${previewImage.naturalWidth} × ${previewImage.naturalHeight} px`;
            imageDetails.style.display = '';
          };
          previewImage.src = previewUrl;
          previewImage.classList.add('visible');

          runRenderPipeline();
        } catch (error) {
          if (error instanceof ValidationError) {
            showError(error.message);
          } else {
            showError('Could not read image.');
          }
          previewImage.classList.remove('visible');
          previewImage.onload = null;
          previewImage.src = '';
        }
      }

      previewArea.addEventListener('click', () => fileInput.click());

      fileInput.addEventListener('change', () => {
        if (isProcessing) return;
        const file = fileInput.files?.[0];
        if (file) handleFile(file).catch(() => showError('Unexpected error.'));
      });

      let dragCounter = 0;

      window.addEventListener('dragenter', (event) => {
        if (!event.dataTransfer?.types.includes('Files')) return;
        event.preventDefault();
        dragCounter++;
        dropOverlay.classList.add('visible');
      });

      window.addEventListener('dragleave', (event) => {
        if (!event.dataTransfer?.types.includes('Files')) return;
        if (dragCounter <= 0) { dragCounter = 0; return; }
        dragCounter--;
        if (dragCounter === 0) {
          dropOverlay.classList.remove('visible');
        }
      });

      window.addEventListener('dragover', (event) => {
        if (event.dataTransfer?.types.includes('Files')) {
          event.preventDefault();
        }
      });

      window.addEventListener('drop', (event) => {
        event.preventDefault();
        dragCounter = 0;
        dropOverlay.classList.remove('visible');
        if (isProcessing) return;
        const file = event.dataTransfer?.files[0];
        if (file) handleFile(file).catch(() => showError('Unexpected error.'));
      });

      slider.addEventListener('input', () => {
        sliderValue.textContent = slider.value;

        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          try {
            runRenderPipeline();
          } catch {
            showError('Unexpected error.');
          }
        }, 50);
      });
    </script>
  </body>
</html>
